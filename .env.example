# Supabase — public (browser + server; safe to expose anon key with RLS)
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR_ANON_KEY

# Supabase — server-only migrations / admin scripts (never expose to client)
SUPABASE_SERVICE_ROLE_KEY=YOUR_SERVICE_ROLE_KEY

# Tracking/ads overrides (optional; falls back to site_settings in Supabase)
NEXT_PUBLIC_GA4_MEASUREMENT_ID=G-XXXXXXXXXX
NEXT_PUBLIC_ADSENSE_CLIENT_ID=ca-pub-1234567890123456

# Optional: Search Console HTML-tag verification content (server-only; overrides site_settings)
GOOGLE_SITE_VERIFICATION=

# Optional newline-separated ads.txt entries (server-side)
ADS_TXT_LINES=
