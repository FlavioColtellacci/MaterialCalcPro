# Firebase Admin (server-only). Project settings → Service accounts → Generate new private key.
# — Paste JSON as ONE LINE, OR point at the downloaded JSON file path (recommended if pasted multi-line broke .env parsing).
# — If you accidentally split JSON across lines, run: node scripts/recover-firebase-key-from-env.mjs
# project_id inside the JSON is enough; FIREBASE_PROJECT_ID is optional.
FIREBASE_PROJECT_ID=your-project-id
FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"your-project-id",...}
# FIREBASE_SERVICE_ACCOUNT_JSON_PATH=/absolute/path/to/serviceAccountKey.json
# GOOGLE_APPLICATION_CREDENTIALS=/absolute/path/to/serviceAccountKey.json

# Tracking/ads overrides (optional; falls back to site_settings in Firestore)
NEXT_PUBLIC_GA4_MEASUREMENT_ID=G-XXXXXXXXXX
NEXT_PUBLIC_ADSENSE_CLIENT_ID=ca-pub-1234567890123456

# Optional: Search Console HTML-tag verification content (server-only; overrides Firestore site_settings)
GOOGLE_SITE_VERIFICATION=

# Optional newline-separated ads.txt entries (server-side)
ADS_TXT_LINES=
